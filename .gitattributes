# Garante que scripts shell chegam com LF no Linux/EC2 (CRLF quebra o bash)
* text=auto
*.sh text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
*.ps1 text eol=crlf
*.pdf binary
*.pptx binary
